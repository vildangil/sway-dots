# Basic Settings
set $mod Mod4
set $term kitty

floating_modifier $mod

# SwayFX
animation_duration_ms 300
corner_radius 8
smart_corner_radius off
layer_effects wofi "corner_radius 8"
blur enable
blur_passes 3
blur_radius 8
blur_noise 0.1
shadows enable
shadow_blur_radius 10
shadow_color #00000044

# Visual
gaps inner 8

font pango: SF Pro 9

default_border pixel 2
for_window [tiling] border pixel 2
for_window [floating] border pixel 2

set $cl_high #a49bb1
set $cl_indi #a49bb1
set $cl_back #1b1928
set $cl_fore #1b1928
set $cl_urge #8e6059

client.focused          $cl_high $cl_high $cl_fore $cl_indi $cl_high
client.focused_inactive $cl_high $cl_back $cl_fore $cl_back $cl_back
client.unfocused        $cl_high $cl_back $cl_fore $cl_high $cl_back
client.urgent           $cl_urge $cl_urge $cl_fore $cl_urge $cl_urge

# Display
output DP-1 resolution 1920x1080@144.001Hz
output HDMI-A-1 resolution 1920x1080

focus output DP-1

output * background '~/Wallpaper/wallpaper.jpg' fill

workspace 1 output DP-1
workspace 2 output HDMI-A-1
workspace 3 output DP-1

exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec tg-ws-proxy
exec 'sleep 3; swaymsg workspace 1'

# Input
input type:keyboard {
    xkb_layout us,ru
    xkb_options grp:alt_shift_toggle
}

# Bindings
bindsym Print+Ctrl+Shift exec grim -g "$(slurp -d)" - | wl-copy

bindsym --to-code $mod+Return exec $term
bindsym --to-code $mod+b exec firefox
bindsym --to-code $mod+t exec Telegram
bindsym --to-code $mod+q kill
bindsym --to-code $mod+r exec wofi --show drun --prompt ""
bindsym --to-code $mod+Shift+s exec grim -g "$(slurp -d)" - | wl-copy
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle

bindsym Print exec grim - | wl-copy
bindsym --to-code $mod+Shift+c reload
bindsym --to-code $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -b 'Yes, exit sway' 'swaymsg exit'

bindsym --to-code $mod+Left focus left
bindsym --to-code $mod+Down focus down
bindsym --to-code $mod+Up focus up
bindsym --to-code $mod+Right focus right

bindsym --to-code $mod+Shift+Left move left
bindsym --to-code $mod+Shift+Down move down
bindsym --to-code $mod+Shift+Up move up
bindsym --to-code $mod+Shift+Right move right

bindsym Ctrl+button4 workspace prev
bindsym Ctrl+button5 workspace next

bindsym --to-code Ctrl+Shift+1 move container to workspace number 1
bindsym --to-code Ctrl+Shift+2 move container to workspace number 2
bindsym --to-code Ctrl+Shift+3 move container to workspace number 3
bindsym --to-code Ctrl+Shift+4 move container to workspace number 4
bindsym --to-code Ctrl+Shift+5 move container to workspace number 5
bindsym --to-code Ctrl+Shift+6 move container to workspace number 6
bindsym --to-code Ctrl+Shift+7 move container to workspace number 7
bindsym --to-code Ctrl+Shift+8 move container to workspace number 8
bindsym --to-code Ctrl+Shift+9 move container to workspace number 9
bindsym --to-code Ctrl+Shift+0 move container to workspace number 10

bindsym --to-code $mod+1 workspace number 1
bindsym --to-code $mod+2 workspace number 2
bindsym --to-code $mod+3 workspace number 3
bindsym --to-code $mod+4 workspace number 4
bindsym --to-code $mod+5 workspace number 5
bindsym --to-code $mod+6 workspace number 6
bindsym --to-code $mod+7 workspace number 7
bindsym --to-code $mod+8 workspace number 8
bindsym --to-code $mod+9 workspace number 9
bindsym --to-code $mod+0 workspace number 10

bindsym --to-code $mod+Shift+1 move container to workspace number 1
bindsym --to-code $mod+Shift+2 move container to workspace number 2
bindsym --to-code $mod+Shift+3 move container to workspace number 3
bindsym --to-code $mod+Shift+4 move container to workspace number 4
bindsym --to-code $mod+Shift+5 move container to workspace number 5
bindsym --to-code $mod+Shift+6 move container to workspace number 6
bindsym --to-code $mod+Shift+7 move container to workspace number 7
bindsym --to-code $mod+Shift+8 move container to workspace number 8
bindsym --to-code $mod+Shift+9 move container to workspace number 9
bindsym --to-code $mod+Shift+0 move container to workspace number 10

bindsym --to-code $mod+s layout stacking
bindsym --to-code $mod+w layout tabbed
bindsym --to-code $mod+e exec dolphin
bindsym --to-code $mod+Shift+space floating toggle
bindsym --to-code $mod+f fullscreen

mode "resize" {
    bindsym Left resize shrink width 25px
    bindsym Down resize grow height 25px
    bindsym Up resize shrink height 25px
    bindsym Right resize grow width 25px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym --to-code $mod+Shift+r mode "resize"

exec_always /home/hypertop/.config/sway/scripts/waybar.sh

include /etc/sway/config.d/*
